{
  "name": "rest-pipeline-js",
  "version": "1.3.5",
  "description": "Pipeline Orchestration Utilities for JavaScript REST API Clients",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./vue": {
      "types": "./dist/esm/vue.d.ts",
      "import": "./dist/esm/vue.js",
      "require": "./dist/cjs/vue.js"
    },
    "./react": {
      "types": "./dist/esm/react.d.ts",
      "import": "./dist/esm/react.js",
      "require": "./dist/cjs/react.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "demo:vue": "npm run start-demo-vite",
    "start-demo-vite": "vite --config vite.config.js"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "rest",
    "api",
    "client",
    "pipeline"
  ],
  "author": "macrulez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/macrulezru/pipeline-js"
  },
  "homepage": "https://macrulez.ru/#/en",
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^27.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "scheduler": "^0.27.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "vue": "^3.5.26",
    "vue-eslint-parser": "^10.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}
