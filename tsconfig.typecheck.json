{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "vitest/importMeta"]
  },
  "include": ["src/**/*.ts", "tests/**/*.test-d.ts"],
  "exclude": ["src/vue-demo"]
}
